  d <- length(setdiff(all_sub_de, union(de, all_sub_novel_de)))
  
  contingency <- matrix(c(a, b, c, d), nrow = 2,
                        dimnames = list(
                          disease_effector = c("in_dataset", "not_in_dataset"),
                          novel_disease_effector   = c("in_dataset", "not_in_dataset")
                        ))

contingency
  contingency <- matrix(c(a, b, c, d), nrow = 2,
